diff --git a/Makefile b/Makefile
index 590fd4c1f2c..39fdee8e9dc 100644
--- a/Makefile
+++ b/Makefile
@@ -359,7 +359,7 @@ KBUILD_CPPFLAGS := -D__KERNEL__ -D__UBOOT__
 
